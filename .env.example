# App
NODE_ENV=development
PORT=5000

# Primary Atlas URI (SRV)
# Example: mongodb+srv://<user>:<pass>@smart-campus-hub.my5t9cf.mongodb.net/smart_campus_hub?retryWrites=true&w=majority&appName=smart-campus-hub
MONGODB_URI=

# Fallback non-SRV URI (used when SRV DNS fails)
# You can point this to Atlas hosts list or local MongoDB
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/smart_campus_hub

# Optional fallback parts (used if MONGODB_URI_FALLBACK is not set)
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DB=smart_campus_hub
MONGODB_USER=smart_campus_hub_user
MONGODB_PASSWORD=Ramya230619

# Connection tuning
MONGODB_FORCE_IPV4=true
MONGODB_RETRIES=3
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=2
